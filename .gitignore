# ── Global ────────────────────────────────────────────────────────────────────
.DS_Store
*.log
*.swp
*.swo
*.swm
*~

# ── Rust (server/) ────────────────────────────────────────────────────────────
server/target/
server/.env
server/uploads/

# ── Node / Next.js (admin-web/) ───────────────────────────────────────────────
admin-web/node_modules/
admin-web/.next/
admin-web/tsconfig.tsbuildinfo
admin-web/.env
admin-web/.env.*
!admin-web/.env.example

# ── Python (scripts/, ml-service/) ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
ml-service/data/
ml-service/.venv/

# ── Xcode (client-ios/) ───────────────────────────────────────────────────────
# User-specific workspace state — not shareable
**/xcuserdata/
**/*.xcuserstate

# Derived + build output
client-ios/DerivedData/
client-ios/build/
client-ios/Build/

# Archives & signing
client-ios/*.xcarchive
client-ios/*.mobileprovision
client-ios/*.codesign

# Package managers (not used, but guard against accidental addition)
client-ios/Pods/
client-ios/Podfile.lock
client-ios/Carthage/Build/
client-ios/.swiftpm/
client-ios/Package.resolved

# Coverage & profiling
client-ios/*.gcda
client-ios/*.gcno
client-ios/*.profraw
client-ios/*.xccoverage

# IDE / editor
.fleet/
.idea/
